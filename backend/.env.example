# Backend environment template for webapp-boilerplate
# Copy to backend/.env for local development and replace placeholder values.

APP_ENV=development
DB_TYPE=sqlite
SQLITE_DB_PATH=app.db

# Required: generate a strong random value (e.g. openssl rand -hex 32)
AUTH_SECRET_KEY=replace-with-strong-random-secret

# Required: one-time setup secret used by /setup initialization flow
INITIAL_SETUP_TOKEN=replace-with-strong-random-token

# Comma-separated CORS origins for frontend apps
CORS_ALLOW_ORIGINS=http://localhost:5173

# Base URLs used in auth links and redirects
AUTH_FRONTEND_BASE_URL=http://localhost:5173
AUTH_BACKEND_BASE_URL=http://localhost:8000

# Cookie security defaults (set COOKIE_SECURE=true in production)
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

# Optional setup-time SMTP defaults (non-sensitive values are returned by /setup/status)
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Optional server-side SMTP fallback used during setup submission.
# This value is not returned by /setup/status.
SMTP_PASSWORD=

# Optional API keys for third-party integrations
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
